{
    "name": "map-app",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "supa-gen-types": "pnpx supabase gen types --lang typescript --local --schema=public > ./lib/types/supabase.ts",
        "supa-config-push": "pnpx supabase config push",
        "supa-reset": "pnpx supabase stop && pnpx supabase start",
        "supa-db-reset": "pnpx supabase db reset --local && pnpm run supa-seed && pnpm run supa-gen-types",
        "supa-db-remote-reset": "pnpx supabase db reset --linked && pnpm run supa-seed",
        "supa-seed": "node scripts/seed.ts"
    },
    "dependencies": {
        "@base-ui/react": "^1.3.0",
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/modifiers": "^9.0.0",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@hookform/resolvers": "^5.2.2",
        "@supabase/ssr": "^0.9.0",
        "@supabase/supabase-js": "^2.98.0",
        "@tabler/icons-react": "^3.37.1",
        "@tanstack/react-table": "^8.21.3",
        "browser-image-compression": "^2.0.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.3.1",
        "embla-carousel-react": "^8.6.0",
        "http-status-codes": "^2.3.0",
        "input-otp": "^1.4.2",
        "mapbox-gl": "^3.19.1",
        "next": "16.1.6",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-dropzone": "^15.0.0",
        "react-hook-form": "^7.71.2",
        "recharts": "2.15.4",
        "sharp": "^0.34.5",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "vaul": "^1.1.2",
        "zod": "^3.25.76"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
